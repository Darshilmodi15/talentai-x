# ─── Required ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=anthropic_api_key_here

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://talentai:talentai_secret@localhost:5432/talentai_db
DATABASE_URL_SYNC=postgresql://talentai:talentai_secret@localhost:5432/talentai_db

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── ChromaDB ─────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ─── Security ─────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production_use_openssl_rand
API_KEY_HEADER=X-API-Key

# ─── App Config ───────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
MAX_UPLOAD_SIZE_MB=10
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ─── Model Config ─────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=all-MiniLM-L6-v2
MATCH_THRESHOLD_AUTO=0.85
MATCH_THRESHOLD_REVIEW=0.60

# ─── Frontend ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
