# ─── Required ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://talentai:talentai_secret@localhost:5432/talentai_db
DATABASE_URL_SYNC=postgresql://talentai:talentai_secret@localhost:5432/talentai_db

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── ChromaDB Cloud ───────────────────────────────────────────────
CHROMA_API_KEY=YOUR_API_KEY
CHROMA_TENANT=266a2f4f-9628-4504-95f1-7b3a6c144859
CHROMA_DATABASE=talentai_db

# ─── Security ─────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production_use_openssl_rand
API_KEY_HEADER=X-API-Key

# ─── App Config ───────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
MAX_UPLOAD_SIZE_MB=10
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ─── Model Config ─────────────────────────────────────────────────
GEMINI_MODEL=cgemini-3.5-flash
EMBEDDING_MODEL=gemini-embedding-2
MATCH_THRESHOLD_AUTO=0.85
MATCH_THRESHOLD_REVIEW=0.60

# ─── Frontend ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
